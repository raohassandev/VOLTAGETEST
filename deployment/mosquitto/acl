# UMS MQTT Access Control List — eclipse-mosquitto v2
#
# Device users (username = device_id):
#   Can publish only to their own telemetry topic.
#   The %u substitution expands to the connecting client's username.
#   A device with username UMS-3076F5A5AD54 can publish to:
#     ums/devices/UMS-3076F5A5AD54/data
#
pattern write ums/devices/%u/data
pattern write ums/devices/%u/status

# Dashboard / MQTT worker user:
#   Needs read access to all device telemetry and write access
#   to command topics so the dashboard can send reboot/reset/OTA commands.
#   Username must match MQTT_USERNAME in the dashboard .env.
#
user dashboard
topic read ums/devices/+/data
topic read ums/devices/+/status
topic write ums/devices/+/command
