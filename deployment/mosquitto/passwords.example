# Create the passwords file for Mosquitto.
# Add the dashboard user (used by mqtt-worker):
# docker run --rm -it -v ${PWD}/mosquitto:/mosquitto/config eclipse-mosquitto:2 mosquitto_passwd -c /mosquitto/config/passwords dashboard
#
# Add each device user (device_id as username, matching MQTT password):
# docker run --rm -it -v ${PWD}/mosquitto:/mosquitto/config eclipse-mosquitto:2 mosquitto_passwd /mosquitto/config/passwords UMS-3076F5A5AD54
# docker run --rm -it -v ${PWD}/mosquitto:/mosquitto/config eclipse-mosquitto:2 mosquitto_passwd /mosquitto/config/passwords UPSMON-B1-01
#
# The device username must match the device_id configured in the firmware portal.
