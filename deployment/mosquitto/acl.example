# Device telemetry topics â€” v1.0.0 topic scheme: ums/devices/{device_id}/data
# Each device authenticates with its deviceId as MQTT username.
pattern write ums/devices/%u/data

# Dashboard/backend (mqtt-worker) reads all device telemetry.
user dashboard
topic read ums/devices/+/data

# Superuser for local dev / certify.sh smoke tests.
# Remove or restrict in production.
user DOCKER-SMOKE-001
topic readwrite #
