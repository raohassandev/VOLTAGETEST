# Copy this to .env and fill in real values before running docker compose
# NEVER commit .env — it contains secrets

POSTGRES_PASSWORD=change-this-strong-random-password
UPS_AUTH_USERNAME=admin
# Use bcrypt hash: node -e "require('bcryptjs').hash('YourPassword',12).then(console.log)"
UPS_AUTH_PASSWORD_HASH=
# 64-char hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UPS_AUTH_TOKEN=replace-with-64-char-hex
MQTT_USERNAME=dashboard
MQTT_PASSWORD=change-this-strong-mqtt-password
# MQTT topic the worker subscribes to — must match firmware publish topic
MQTT_TOPIC=ums/devices/+/data
ENABLE_EMBEDDED_BROKER=false
ENABLE_INPROCESS_WORKER=false
ENABLE_MANUAL_TELEMETRY_POST=false

# Offline commercial licensing. Put only the Automatrix public key here.
# The private signing key must stay outside this repository and outside the UMS host.
UMS_LICENSE_ENFORCEMENT=enabled
UMS_LICENSE_PATH=/app/data/license/ums-license.json
UMS_LICENSE_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_AUTOMATRIX_PUBLIC_KEY\n-----END PUBLIC KEY-----"

# Password used by certify.sh for the auth smoke test.
# Must match the admin account password configured in UPS_AUTH_PASSWORD_HASH above.
# Set before running: CERT_ADMIN_PASSWORD=your-actual-admin-password bash certify.sh
# CERT_ADMIN_PASSWORD=change-this-to-your-actual-admin-password
