# Copy this to .env and fill in real values before running docker compose
# NEVER commit .env — it contains secrets

POSTGRES_PASSWORD=change-this-strong-random-password
UPS_AUTH_USERNAME=admin
# Use bcrypt hash: node -e "require('bcryptjs').hash('YourPassword',12).then(console.log)"
UPS_AUTH_PASSWORD_HASH=
# 64-char hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UPS_AUTH_TOKEN=replace-with-64-char-hex
MQTT_USERNAME=dashboard
MQTT_PASSWORD=change-this-strong-mqtt-password
# MQTT topic the worker subscribes to — must match firmware publish topic
MQTT_TOPIC=ums/devices/+/data
ENABLE_EMBEDDED_BROKER=false
ENABLE_INPROCESS_WORKER=false
ENABLE_MANUAL_TELEMETRY_POST=false
