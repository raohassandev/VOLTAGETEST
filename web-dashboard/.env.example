# ── Authentication ────────────────────────────────────────────────────────────
# Admin username (default: admin)
UPS_AUTH_USERNAME=admin

# Plain-text password (only for development / non-production deployments)
# UPS_AUTH_PASSWORD=change-this-password

# Bcrypt hash of the admin password (recommended for production).
# Generate: node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
UPS_AUTH_PASSWORD_HASH=$2b$12$replacethiswithyourrealbcrypthash

# Long random string used as the session token value stored in the cookie.
# Generate: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
UPS_AUTH_TOKEN=replace-with-a-64-char-hex-string-generated-by-crypto-randomBytes

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. If not set, the dashboard falls back to JSON files.
DATABASE_URL=postgresql://ups_user:change-this-db-password@localhost:5432/upsmon

# ── MQTT broker ───────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=dashboard
MQTT_PASSWORD=change-this-mqtt-password
MQTT_TOPIC=building/+/ups/+/telemetry

# Device offline threshold (seconds). Worker marks a device offline if no
# telemetry is received within this window.
OFFLINE_THRESHOLD_SECS=60
