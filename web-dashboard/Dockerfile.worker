FROM node:22-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

FROM node:22-alpine AS runner
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY prisma ./prisma
COPY worker ./worker
COPY src/lib/alarm-engine.ts ./src/lib/alarm-engine.ts
COPY package*.json ./
COPY tsconfig.json ./

RUN node_modules/.bin/prisma generate

CMD ["node_modules/.bin/tsx", "worker/mqtt-worker.ts"]
