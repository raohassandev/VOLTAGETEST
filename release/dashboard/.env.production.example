# ── UMS Dashboard — Production Environment Template ──────────────────────────
#
# Copy this file to .env on your production server.
# Never commit .env to version control.
# All values marked REQUIRED must be set before starting the application.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────────────────────

# Admin username
# REQUIRED
UPS_AUTH_USERNAME=admin

# Bcrypt hash of the admin password.
# REQUIRED in production — the app will fail startup without this.
# Generate with:
#   node -e "const b=require('bcryptjs'); b.hash('YourStrongPassword',12).then(console.log)"
# Use cost factor 12 or higher.
UPS_AUTH_PASSWORD_HASH=$2b$12$REPLACE_THIS_WITH_YOUR_REAL_BCRYPT_HASH

# Session token — stored in the browser cookie to identify authenticated sessions.
# REQUIRED in production.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 bytes / 64 hex characters. Rotate this value to invalidate all sessions.
UPS_AUTH_TOKEN=REPLACE_WITH_64_CHAR_HEX_FROM_crypto_randomBytes_32

# Dev bypass — NEVER set to true in production.
# ALLOW_DEV_AUTH=false

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# REQUIRED
# Use a strong password for ups_user.
DATABASE_URL=postgresql://ups_user:CHANGE_THIS_DB_PASSWORD@postgres:5432/upsmon

# ── MQTT Broker ───────────────────────────────────────────────────────────────

# MQTT broker URL.
# REQUIRED
# Use internal Docker network hostname (mosquitto) when using docker-compose.
MQTT_BROKER_URL=mqtt://mosquitto:1883

# MQTT credentials — must match mosquitto password file.
# REQUIRED if broker has auth enabled (recommended).
MQTT_USERNAME=dashboard
MQTT_PASSWORD=CHANGE_THIS_MQTT_PASSWORD

# MQTT topic subscription pattern. Must match firmware v2.1.0 publish topic.
MQTT_TOPIC=ums/devices/+/data

# ── Operational ──────────────────────────────────────────────────────────────

# Seconds without telemetry before a device is marked offline.
# Default: 60
OFFLINE_THRESHOLD_SECS=60

# Node environment — must be production for production deployments.
NODE_ENV=production

# ── PostgreSQL (docker-compose service) ──────────────────────────────────────
# These are used by the postgres container, not the dashboard directly.
# Must match the password in DATABASE_URL above.

POSTGRES_DB=upsmon
POSTGRES_USER=ups_user
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD

# ── Security checklist ───────────────────────────────────────────────────────
# Before deploying, confirm:
# [ ] UPS_AUTH_PASSWORD_HASH is a real bcrypt hash of a strong password
# [ ] UPS_AUTH_TOKEN is a 64-char random hex string
# [ ] ALLOW_DEV_AUTH is not set (or explicitly false)
# [ ] POSTGRES_PASSWORD and DATABASE_URL password match
# [ ] MQTT_PASSWORD matches the mosquitto password file
# [ ] This .env file is not committed to git
# [ ] File permissions restrict read access (chmod 600 .env on Linux)
