NODE_ENV=production
PORT=3303
DATABASE_URL=postgresql://ums_user:CHANGE_THIS_DB_PASSWORD@localhost:5432/ums_local
UPS_AUTH_USERNAME=admin
UPS_AUTH_PASSWORD_HASH=REPLACE_THIS_WITH_BCRYPT_HASH
UPS_AUTH_TOKEN=REPLACE_WITH_64_CHAR_HEX_FROM_crypto_randomBytes_32
UMS_LICENSE_ENFORCEMENT=enabled
UMS_LICENSE_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_AUTOMATRIX_PUBLIC_KEY\n-----END PUBLIC KEY-----"
UMS_LICENSE_DIR=/var/lib/voltagetest/license
MQTT_BROKER_URL=mqtt://localhost:1883
ENABLE_EMBEDDED_BROKER=false
ENABLE_INPROCESS_WORKER=false
